{
  "name": "mistvault",
  "version": "0.1.0",
  "description": "MistVault Windows local mistake notebook for exam review.",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "verify:db": "npm run rebuild:native && node scripts/verify-db.mjs",
    "verify:ocr-runtime": "node scripts/verify-ocr-runtime.mjs",
    "verify:extraction-stage1a": "node scripts/verify-extraction-stage1a.mjs",
    "verify:extraction-stage1b": "node scripts/verify-extraction-stage1b.mjs",
    "verify:extraction-text": "node scripts/verify-extraction-stage1a.mjs text",
    "verify:extraction-cache": "node scripts/verify-extraction-stage1a.mjs cache",
    "verify:extraction-errors": "node scripts/verify-extraction-stage1a.mjs errors",
    "verify:extraction-ocr": "node scripts/verify-extraction-stage1a.mjs ocr"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "docx": "^9.7.1",
    "jszip": "3.10.1",
    "pdfjs-dist": "4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
